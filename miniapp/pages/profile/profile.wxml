<!-- 我的 -->
<view class="page">
  <!-- User Info -->
  <view class="user-section" bindtap="{{loggedIn ? '' : 'goLogin'}}">
    <image class="user-avatar" src="{{userInfo ? userInfo.avatarUrl : ''}}" mode="aspectFill" wx:if="{{userInfo && userInfo.avatarUrl}}" />
    <view class="user-avatar placeholder" wx:else>👤</view>
    <view class="user-info">
      <text class="user-name">{{userInfo ? userInfo.nickName : '点击登录'}}</text>
      <text class="user-detail">{{loggedIn ? '查看个人资料 ›' : '登录享更多服务'}}</text>
    </view>
  </view>

  <!-- Order Status -->
  <view class="order-status" wx:if="{{loggedIn}}">
    <view class="status-item">
      <text class="status-icon">📋</text>
      <text class="status-label">待付款</text>
    </view>
    <view class="status-item">
      <text class="status-icon">📦</text>
      <text class="status-label">待发货</text>
    </view>
    <view class="status-item">
      <text class="status-icon">🚚</text>
      <text class="status-label">待收货</text>
    </view>
    <view class="status-item">
      <text class="status-icon">⭐</text>
      <text class="status-label">待评价</text>
    </view>
  </view>

  <!-- My Orders -->
  <view class="section" wx:if="{{loggedIn}}">
    <view class="section-header">
      <text class="section-title">我的订单</text>
    </view>
    <view class="order-item" wx:for="{{orders}}" wx:key="id" data-id="{{item.id}}" bindtap="goOrder">
      <text class="order-id">订单号: {{item.id}}</text>
      <text class="order-status-badge">{{item.status || '已完成'}}</text>
      <text class="order-total">¥{{item.total?.toFixed(2)}}</text>
    </view>
    <text class="empty" wx:if="{{orders.length === 0 && !loading}}">暂无订单</text>
  </view>

  <!-- Tools -->
  <view class="section" wx:if="{{loggedIn}}">
    <view class="menu-item">
      <text>📖 头皮知识库</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item">
      <text>📊 检测记录</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item">
      <text>🎯 我的推荐</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="logout">
      <text style="color:#dc2626;">退出登录</text>
    </view>
  </view>
</view>
