.page { min-height: 100vh; background: #0a0a0a; }
.detect-init { padding: 80rpx 40rpx; text-align: center; }
.detect-header { margin-bottom: 60rpx; }
.detect-icon { font-size: 100rpx; margin-bottom: 30rpx; }
.detect-title { font-size: 40rpx; font-weight: 600; color: #e8d5b7; margin-bottom: 20rpx; }
.detect-desc { font-size: 28rpx; color: #999; line-height: 1.6; }

.steps { text-align: left; margin-bottom: 60rpx; }
.step { display: flex; align-items: flex-start; margin-bottom: 30rpx; }
.step-num {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: #c9a96e;
  color: #0a0a0a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.step-body { display: flex; flex-direction: column; }
.step-title { font-size: 28rpx; color: #e8d5b7; font-weight: 500; }
.step-desc { font-size: 24rpx; color: #777; margin-top: 6rpx; }

.detect-btn { margin-top: 40rpx; }
.detect-tip { display: block; margin-top: 20rpx; font-size: 24rpx; color: #555; }

.detecting {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}
.detecting-circle {
  width: 120rpx; height: 120rpx;
  border: 6rpx solid rgba(201,169,110,0.2);
  border-top: 6rpx solid #c9a96e;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 40rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }
.detecting-text { font-size: 32rpx; color: #e8d5b7; }
.detecting-sub { font-size: 26rpx; color: #666; margin-top: 10rpx; }

/* ---------- 报告样式 ---------- */
.report { padding: 40rpx 30rpx; padding-bottom: 80rpx; }

/* 综合评分头 */
.report-header { text-align: center; padding: 50rpx 0 30rpx; }
.report-score { font-size: 100rpx; font-weight: 700; color: #c9a96e; }
.report-score-label { font-size: 26rpx; color: #666; margin-top: 10rpx; }
.report-level {
  display: inline-block;
  padding: 8rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  margin-top: 20rpx;
}
.level-excellent { background: rgba(7, 193, 96, 0.15); color: #07c160; }
.level-good { background: rgba(201, 169, 110, 0.15); color: #c9a96e; }
.level-normal { background: rgba(238, 90, 82, 0.15); color: #ee5a52; }

.report-type { text-align: center; font-size: 30rpx; color: #e8d5b7; font-weight: 600; margin: 10rpx 0; }
.report-summary { text-align: center; font-size: 26rpx; color: #999; margin-bottom: 40rpx; }

/* 四维量表 */
.report-dimensions { margin-bottom: 30rpx; }
.dimension { margin-bottom: 22rpx; }
.dimension-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.dimension-label { font-size: 26rpx; color: #bbb; }
.dimension-right { display: flex; align-items: center; gap: 16rpx; }
.dimension-desc { font-size: 22rpx; color: #666; }
.dimension-score { font-size: 24rpx; color: #c9a96e; }
.dimension-bar {
  height: 12rpx;
  background: #222;
  border-radius: 10rpx;
  overflow: hidden;
}
.dimension-fill {
  height: 100%;
  background: linear-gradient(90deg, #c9a96e, #e8d5b7);
  border-radius: 10rpx;
  transition: width 0.8s ease;
}

/* 通用卡片 */
.section { margin-bottom: 24rpx; }
.card {
  background: #1a1a2e;
  border-radius: 20rpx;
  padding: 30rpx;
  border: 1px solid rgba(201,169,110,0.1);
}
.card-title { font-size: 30rpx; font-weight: 600; color: #e8d5b7; margin-bottom: 20rpx; }
.card-subtitle { font-size: 24rpx; color: #c9a96e; margin: 16rpx 0 10rpx; }

/* 分析发现 */
.findings { margin-bottom: 10rpx; }
.finding { display: flex; margin-bottom: 12rpx; }
.finding-bullet { color: #c9a96e; margin-right: 12rpx; font-size: 24rpx; }
.finding-text { font-size: 26rpx; color: #999; line-height: 1.6; flex: 1; }

.root-causes { margin-top: 10rpx; padding-top: 16rpx; border-top: 1px solid rgba(201,169,110,0.08); }
.cause { display: flex; margin-bottom: 8rpx; }
.cause-bullet { color: #888; margin-right: 12rpx; font-size: 22rpx; }
.cause-text { font-size: 24rpx; color: #777; line-height: 1.5; }

/* 护理方案 */
.routine-block { margin-bottom: 16rpx; }
.routine-label { font-size: 24rpx; color: #c9a96e; margin-bottom: 8rpx; font-weight: 500; }
.routine-item { display: flex; margin-bottom: 8rpx; }
.routine-dot { color: #c9a96e; margin-right: 12rpx; font-size: 20rpx; }
.routine-text { font-size: 24rpx; color: #999; line-height: 1.5; flex: 1; }
.caution-label { color: #f5a623; }
.caution-dot { color: #f5a623; }
.caution-text { color: #aa7733; }

/* 推荐产品 */
.product-rec {
  background: rgba(201,169,110,0.04);
  border: 1px solid rgba(201,169,110,0.1);
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.rec-category { font-size: 28rpx; color: #e8d5b7; font-weight: 600; margin-bottom: 6rpx; }
.rec-target { font-size: 24rpx; color: #999; margin-bottom: 12rpx; }
.rec-label { font-size: 24rpx; color: #888; }
.rec-ingredients { margin-bottom: 8rpx; display: flex; flex-wrap: wrap; align-items: center; gap: 6rpx; }
.rec-tag {
  display: inline-block;
  font-size: 20rpx;
  background: rgba(201,169,110,0.12);
  color: #c9a96e;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.rec-brands { font-size: 24rpx; color: #888; margin-bottom: 8rpx; }
.rec-guide { font-size: 22rpx; color: #666; margin-bottom: 12rpx; line-height: 1.5; }
.rec-links { display: flex; gap: 20rpx; }
.rec-link {
  font-size: 22rpx;
  color: #c9a96e;
  text-decoration: underline;
  padding: 4rpx 0;
}

/* 简单建议 */
.tip { display: flex; margin-bottom: 14rpx; }
.tip-dot { color: #c9a96e; margin-right: 16rpx; }
.tip-text { font-size: 26rpx; color: #999; line-height: 1.5; }

/* 底部按钮 */
.report-nav { margin-top: 40rpx; }
.report-nav .btn-primary { margin-bottom: 20rpx; }
.btn-secondary {
  background: transparent !important;
  color: #999 !important;
  border: 1px solid #333 !important;
  border-radius: 50rpx !important;
  padding: 24rpx !important;
  font-size: 28rpx !important;
}

/* AI生成标识 */
.ai-badge-wrap {
  text-align: center;
  margin-bottom: 12px;
}
.ai-badge {
  display: inline-block;
  padding: 4px 12px;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 11px;
  border-radius: 4px;
  letter-spacing: 1px;
}
