<view class="page">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-circle"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!loading && detections.length === 0}}" class="empty">
    <view class="empty-icon">📋</view>
    <view class="empty-title">暂无检测记录</view>
    <view class="empty-desc">完成一次AI头皮检测，查看你的专属健康报告</view>
    <button class="btn-primary" bindtap="newDetect">去检测</button>
  </view>

  <!-- 检测列表 -->
  <view wx:else class="list">
    <view class="list-header">
      <text class="list-title">检测记录</text>
      <text class="list-count">共 {{detections.length}} 次</text>
    </view>

    <view class="detect-card" wx:for="{{detections}}" wx:key="id" data-id="{{item.id}}" bindtap="viewReport">
      <!-- 左侧：分数圆环 -->
      <view class="card-score-wrap">
        <view class="card-score-circle" style="background: conic-gradient(#c9a96e {{getScorePercent(item.result?.overall?.score || item.overall?.score || 0)}}%, #222 0%)">
          <view class="card-score-inner">
            <text class="card-score-num">{{item.result?.overall?.score || item.overall?.score || '?'}}</text>
          </view>
        </view>
        <text class="card-score-level">{{item.result?.overall?.level || item.overall?.level || '--'}}</text>
      </view>

      <!-- 右侧：摘要 -->
      <view class="card-body">
        <text class="card-hairtype">{{item.result?.hairType || item.hairType || '头皮检测'}}</text>
        <text class="card-date">{{formatDate(item.createdAt)}}</text>
        <view class="card-dimensions">
          <text class="card-dim" wx:for="{{getDimList(item)}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
