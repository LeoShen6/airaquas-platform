<!-- 产品列表 -->
<view class="page">
  <!-- Category Tabs -->
  <scroll-view class="category-tabs" scroll-x>
    <view class="tab {{currentCategory === item ? 'active' : ''}}" 
          wx:for="{{categories}}" wx:key="*this"
          data-cat="{{item}}" bindtap="filterCategory">
      {{categoryNames[item] || item}}
    </view>
  </scroll-view>

  <!-- Product Grid -->
  <view class="product-grid">
    <view class="product-card" wx:for="{{products}}" wx:key="id" 
          data-id="{{item.id}}" bindtap="goProduct">
      <image class="product-image" src="{{item.image_url}}" mode="aspectFit" lazy-load />
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <text class="product-price">¥{{item.price}}</text>
        <view class="product-tags">
          <text class="tag" wx:for="{{item.tags || []}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中...</view>
  <view class="empty" wx:elif="{{products.length === 0}}">
    <text>暂无产品</text>
  </view>
</view>
