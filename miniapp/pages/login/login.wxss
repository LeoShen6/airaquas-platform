/* 登录 */
.login-container {
  display: flex; flex-direction: column; align-items: center;
  padding: 40px 24px;
}
.logo-area { text-align: center; margin-bottom: 40px; }
.logo-icon { font-size: 64px; display: block; margin-bottom: 12px; }
.logo-title { font-size: 28px; font-weight: 800; color: #1c1917; display: block; margin-bottom: 6px; }
.logo-sub { font-size: 14px; color: #999; }

.login-card {
  background: white; border-radius: 16px;
  padding: 32px 24px; width: 100%;
  box-sizing: border-box; box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  text-align: center;
}
.login-title { font-size: 20px; font-weight: 700; color: #1c1917; display: block; margin-bottom: 8px; }
.login-desc { font-size: 14px; color: #999; display: block; margin-bottom: 32px; }
.wx-login-btn {
  background: linear-gradient(135deg, #2D7D46, #3b9b5a);
  color: white; border: none; border-radius: 12px;
  padding: 14px; font-size: 16px; font-weight: 600;
  width: 100%; margin-bottom: 16px;
  display: flex; align-items: center; justify-content: center;
}
.wx-login-btn::after { border: none; }
.login-tip { font-size: 12px; color: #bbb; }
